      '3D HNCO'       
      '3D CBCA(CO)NH' 
      '3D HCCH-TOCSY' 
      '3D HBHA(CO)NH' 
      '3D HCCH-COSY'  

   stop_

   loop_
      _Sample_label

      $sample_1 
      $sample_2 

   stop_

